rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // News images
    match /news/{allPaths=**} {
      allow read;
      allow write: if request.auth != null; // Simplified for spark, user mentioned admin token but usually role in firestore is easier
    }

    // Epaper assets
    match /epaper/{allPaths=**} {
      allow read;
      allow write: if request.auth != null; 
    }
  }
}
