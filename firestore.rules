rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🎭 SECURITY HELPERS
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Logic: User must be signed in AND have role 'admin' in their user document
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // 🗞️ EDITIONS & PAGES (Public for Readers, Admin for Management)
    match /editions/{editionId} {
      // Public Read: No login required to read the newspaper
      allow read: if true; 
      
      // Admin Write: Only verified admins can create/update/delete
      allow write: if isAdmin();
    }

    // 📰 NEWS ARTICLES (General News Feed)
    match /news/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 📂 LEGACY COLLECTIONS
    match /epaper_pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // 👤 USER PROFILES
    match /users/{userId} {
      // Allow anybody to be created (sign up), but only user or admin can read/edit
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // 🛡️ DEFAULT: DENY EVERYTHING ELSE
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
